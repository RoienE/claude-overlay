{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "claude-overlay",
  "version": "0.5.1",
  "identifier": "com.claude-overlay.application",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "main",
        "title": "Claude Usage",
        "width": 260,
        "height": 200,
        "minWidth": 200,
        "minHeight": 120,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "resizable": true,
        "skipTaskbar": true,
        "shadow": false,
        "focus": true
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "minimumSystemVersion": "11.0"
    }
  },
  "plugins": {
    "shell": {
      "open": true
    },
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDk2ODY4MkQwMjZFNzNFNDEKUldSQlB1Y20wSUtHbGo3MWJpbFlidnhYb3BOSGlIdk1hQWJyZGtWVWNGRmxFNlkva3V5Z0NoQWoK",
      "endpoints": [
        "https://github.com/RoienE/claude-overlay/releases/latest/download/latest.json"
      ],
      "windows": { "installMode": "passive" }
    }
  }
}
